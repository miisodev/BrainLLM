# BrainLLM MCP — environment variables
# Copy this file to .env and fill in your values.

# URL of your TriliumNext instance
# Local desktop (default):
TRILIUM_BASE_URL=http://localhost:8080
# Remote / cloud (VPS or reverse proxy):
# TRILIUM_BASE_URL=https://trilium.yourdomain.com

# ETAPI token — create in Trilium: Options → ETAPI → Create token
TRILIUM_ETAPI_TOKEN=

# ── HTTP connector mode (Railway / remote) ────────────────────────────────────
# When PORT is set the server starts an HTTP/SSE connector instead of stdio.
# Railway sets PORT automatically; do NOT set it for local Claude Code usage.
# PORT=8080

# Bearer token that all MCP clients must send as Authorization: Bearer <token>.
# Generate with: openssl rand -hex 32
# MCP_AUTH_TOKEN=

# ── Config persistence (Railway / persistent-volume deploys) ──────────────────
# Absolute path where brainllm.json should be read/written.
# Set this to a mounted volume path so config survives container redeploys.
# Leave unset for local/stdio use — defaults to the directory next to the bundle.
# BRAINLLM_CONFIG=/data/brainllm.json

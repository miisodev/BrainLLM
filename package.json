{
  "name": "brainllm",
  "version": "5.0.0",
  "description": "MCP server that turns TriliumNext Notes into a persistent, graph-structured second brain for Claude and other LLM clients.",
  "author": "Kevin Miiso <miisodev@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/miisodev/BrainLLM.git"
  },
  "homepage": "https://github.com/miisodev/BrainLLM#readme",
  "bugs": {
    "url": "https://github.com/miisodev/BrainLLM/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "trilium",
    "trilium-next",
    "second-brain",
    "knowledge-graph",
    "llm",
    "claude",
    "ai"
  ],
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outfile dist/index.js --target bun",
    "start": "bun run dist/index.js",
    "test": "bun run src/test.ts",
    "init": "bun run src/init.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.0.0"
  }
}
